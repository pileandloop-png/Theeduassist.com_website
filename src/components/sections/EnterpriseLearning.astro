---
---

<section class="py-24 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

            {/* Left Side: Content */}
            <div>
                <div class="inline-flex items-center space-x-2 bg-brand-softBg px-4 py-2 rounded-full mb-6 border border-brand-border/30">
                    <span class="w-2 h-2 rounded-full bg-brand-primary"></span>
                    <span class="text-sm font-bold text-brand-navy tracking-wide uppercase">Corporate & Enterprise</span>
                </div>

                <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">
                    Corporate and enterprise learning systems
                </h2>
                <p class="text-lg text-slate-600 mb-8 leading-relaxed">
                    For businesses, training departments, institutes, NGOs, publishers, and larger organizations, TheEduAssist can help plan and build structured learning systems for onboarding, compliance training, customer education, partner training, product training, internal academies, LMS migration, and SCORM-ready content.
                </p>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
                    <div class="flex items-center space-x-3">
                        <svg class="w-5 h-5 text-brand-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span class="text-slate-700 font-medium">Employee Onboarding</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <svg class="w-5 h-5 text-brand-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span class="text-slate-700 font-medium">Compliance Training</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <svg class="w-5 h-5 text-brand-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span class="text-slate-700 font-medium">Partner Education</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <svg class="w-5 h-5 text-brand-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span class="text-slate-700 font-medium">Customer Portals</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <svg class="w-5 h-5 text-brand-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span class="text-slate-700 font-medium">LMS Migration</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <svg class="w-5 h-5 text-brand-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span class="text-slate-700 font-medium">SCORM / Articulate</span>
                    </div>
                </div>

                <div class="bg-slate-50 p-6 rounded-xl border border-slate-200 mb-8">
                    <p class="text-sm text-slate-600">
                        <span class="font-bold text-brand-navy">Pricing context:</span> Enterprise projects are scoped after discovery. Final pricing depends on platform, learner volume, content volume, integrations, reporting needs, timeline, and support requirements.
                    </p>
                </div>

                <div class="flex flex-col sm:flex-row gap-4">
                    <button type="button" class="btn-enterprise-project inline-flex items-center justify-center px-6 py-3.5 border border-transparent text-base font-bold rounded-md text-white bg-brand-primary hover:bg-brand-navy transition-colors shadow-sm focus-ring w-full sm:w-auto">
                        Start an Enterprise Learning Project
                    </button>
                    <a href="/book-free-audit/?project=enterprise-learning&source=enterprise-section" class="inline-flex items-center justify-center px-6 py-3.5 border border-slate-300 text-base font-medium rounded-md text-brand-navy bg-white hover:bg-slate-50 transition-colors focus-ring w-full sm:w-auto">
                        Submit Project Details
                    </a>
                </div>
            </div>

            {/* Right Side: Process Diagram */}
            <div class="relative">
                <div class="absolute inset-0 bg-gradient-to-br from-brand-softBg to-transparent rounded-3xl transform rotate-3"></div>
                <div class="relative bg-white border border-slate-200 rounded-3xl p-8 shadow-xl">
                    <h3 class="text-xl font-bold text-brand-navy mb-8 text-center border-b border-slate-100 pb-4">Enterprise Project Flow</h3>

                    <div class="flex flex-col space-y-4">
                        {/* Step 1 */}
                        <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 flex items-center shadow-sm relative z-10">
                            <div class="w-10 h-10 rounded-full bg-white border border-slate-200 flex items-center justify-center font-bold text-brand-primary shadow-sm mr-4 flex-shrink-0">1</div>
                            <div>
                                <h4 class="font-bold text-brand-navy text-sm">Business Need</h4>
                                <p class="text-xs text-slate-500 mt-1">Identify goals & audience</p>
                            </div>
                        </div>

                        <div class="w-full flex justify-center -my-3 relative z-0">
                            <div class="w-px h-8 bg-brand-border/50"></div>
                        </div>

                        {/* Step 2 */}
                        <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 flex items-center shadow-sm relative z-10">
                            <div class="w-10 h-10 rounded-full bg-white border border-slate-200 flex items-center justify-center font-bold text-brand-primary shadow-sm mr-4 flex-shrink-0">2</div>
                            <div>
                                <h4 class="font-bold text-brand-navy text-sm">Learning Strategy</h4>
                                <p class="text-xs text-slate-500 mt-1">Architect the experience</p>
                            </div>
                        </div>

                        <div class="w-full flex justify-center -my-3 relative z-0">
                            <div class="w-px h-8 bg-brand-border/50"></div>
                        </div>

                        {/* Step 3 */}
                        <div class="bg-brand-softBg border border-brand-border/50 rounded-xl p-4 flex items-center shadow-sm relative z-10 transform translate-x-2">
                            <div class="w-10 h-10 rounded-full bg-brand-primary text-white flex items-center justify-center font-bold shadow-md mr-4 flex-shrink-0">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                            </div>
                            <div>
                                <h4 class="font-bold text-brand-navy text-sm">LMS / Platform Setup</h4>
                                <p class="text-xs text-slate-600 mt-1">Configure and build</p>
                            </div>
                        </div>

                        <div class="w-full flex justify-center -my-3 relative z-0">
                            <div class="w-px h-8 bg-brand-border/50"></div>
                        </div>

                        {/* Step 4 */}
                        <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 flex items-center shadow-sm relative z-10">
                            <div class="w-10 h-10 rounded-full bg-white border border-slate-200 flex items-center justify-center font-bold text-brand-primary shadow-sm mr-4 flex-shrink-0">4</div>
                            <div>
                                <h4 class="font-bold text-brand-navy text-sm">Course Content</h4>
                                <p class="text-xs text-slate-500 mt-1">Upload and organize assets</p>
                            </div>
                        </div>

                        <div class="w-full flex justify-center -my-3 relative z-0">
                            <div class="w-px h-8 bg-brand-border/50"></div>
                        </div>

                        {/* Step 5 */}
                        <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 flex items-center shadow-sm relative z-10">
                            <div class="w-10 h-10 rounded-full bg-white border border-slate-200 flex items-center justify-center font-bold text-brand-primary shadow-sm mr-4 flex-shrink-0">5</div>
                            <div>
                                <h4 class="font-bold text-brand-navy text-sm">Learner Experience</h4>
                                <p class="text-xs text-slate-500 mt-1">Test flows & accessibility</p>
                            </div>
                        </div>

                        <div class="w-full flex justify-center -my-3 relative z-0">
                            <div class="w-px h-8 bg-brand-border/50"></div>
                        </div>

                        {/* Step 6 */}
                        <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 flex items-center shadow-sm relative z-10">
                            <div class="w-10 h-10 rounded-full bg-white border border-slate-200 flex items-center justify-center font-bold text-brand-primary shadow-sm mr-4 flex-shrink-0">6</div>
                            <div>
                                <h4 class="font-bold text-brand-navy text-sm">Reporting & Support</h4>
                                <p class="text-xs text-slate-500 mt-1">Track and maintain</p>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<script>
    import { openStartPackageChat } from '../../utils/tawkSales';

    document.addEventListener('DOMContentLoaded', () => {
        const btns = document.querySelectorAll('.btn-enterprise-project');
        btns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                openStartPackageChat({
                    packageSlug: 'enterprise-learning-systems',
                    packageName: 'Enterprise Learning Systems',
                    packagePrice: 'Custom quote after scope review',
                    sourceCta: 'enterprise-learning-project',
                    packageAudience: 'corporate_enterprise'
                });
            });
        });
    });
</script>
