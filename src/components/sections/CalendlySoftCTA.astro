---
interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
import { ctaBlocks } from '../../data/ctaBlocks';
---
<div class={`text-center border-t border-slate-200 pt-8 mt-8 ${className}`}>
  <h3 class="text-lg font-bold mb-4">{ctaBlocks.calendly.text.split('?')[0]}?</h3>
  <p class="text-slate-600 mb-6">{ctaBlocks.calendly.text.split('?')[1].trim()}</p>
  <a
    href={ctaBlocks.calendly.href}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block bg-blue-600 text-white px-6 py-3 rounded-md font-medium hover:bg-blue-700 transition-colors"
  >
    {ctaBlocks.calendly.label}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline-block ml-2 -mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </a>
</div>
