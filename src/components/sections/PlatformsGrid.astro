---
import { platformGroups } from '../../data/platforms';
---

<section class="py-24 bg-slate-50 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">Platforms and learning systems we can support</h2>
            <p class="text-lg text-slate-600 leading-relaxed">
                Whether you are building a creator course, a coaching program, a corporate training portal, an internal academy, or SCORM-ready learning content, TheEduAssist helps structure the learning experience and match the build to the right platform.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
            {platformGroups.map((group) => (
                <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300">
                    <div class="w-12 h-12 rounded-xl bg-brand-softBg flex items-center justify-center mb-6 border border-brand-border/30">
                        <svg class="w-6 h-6 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-brand-navy mb-4">{group.category}</h3>
                    <ul class="space-y-3">
                        {group.examples.map((example) => (
                            <li class="flex items-start text-slate-600">
                                <svg class="w-5 h-5 text-brand-accent mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                <span>{example}</span>
                            </li>
                        ))}
                    </ul>
                </div>
            ))}
        </div>

        <div class="text-center bg-white rounded-2xl p-10 border border-slate-200 shadow-sm max-w-4xl mx-auto">
            <h3 class="text-2xl font-bold text-brand-navy mb-4">Not sure which platform fits?</h3>
            <p class="text-slate-600 mb-8 max-w-2xl mx-auto">We help structure, design, migrate, and build learning experiences across these types of systems. We can guide you to the right choice based on your goals.</p>
            <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
                <button type="button" class="btn-platform-guidance inline-flex items-center justify-center px-8 py-3.5 border border-transparent text-base font-bold rounded-md text-white bg-brand-primary hover:bg-brand-navy transition-colors w-full sm:w-auto shadow-sm focus-ring">
                    Talk to Sales
                    <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                </button>
                <a href="/services/" class="inline-flex items-center justify-center px-8 py-3.5 border border-slate-300 text-base font-medium rounded-md text-brand-navy bg-white hover:bg-slate-50 transition-colors w-full sm:w-auto focus-ring">
                    View Services
                </a>
            </div>
            <p class="text-xs text-slate-500 mt-6">* We are an independent agency. We do not claim official partnership with these platforms unless explicitly stated.</p>
        </div>
    </div>
</section>

<script>
    import { openGeneralSalesChat } from '../../utils/tawkSales';

    document.addEventListener('DOMContentLoaded', () => {
        const btns = document.querySelectorAll('.btn-platform-guidance');
        btns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                openGeneralSalesChat({
                    intent: 'platform_guidance',
                    sourceCta: 'platform-guidance-homepage',
                    selected_platform: 'not_sure_yet'
                });
            });
        });
    });
</script>
