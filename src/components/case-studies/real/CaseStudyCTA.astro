---
const { study } = Astro.props;
---
<section class="bg-[#27496D] py-20 mt-12">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
      {study.ctaTitle}
    </h2>
    <p class="text-xl text-blue-100 mb-10 leading-relaxed max-w-3xl mx-auto">
      {study.ctaText}
    </p>

    <div class="flex flex-wrap justify-center gap-4">
      <a href="/book-free-audit/" class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-lg font-bold rounded-md text-[#27496D] bg-[#77BA55] hover:bg-[#65A344] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-[#27496D] focus:ring-[#77BA55] shadow-lg transition-colors duration-200">
        Get 24–48 Hour Review
      </a>
      <a href="/services/" class="inline-flex items-center justify-center px-8 py-4 border-2 border-white/20 text-lg font-bold rounded-md text-white hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-[#27496D] focus:ring-white transition-colors duration-200">
        View Services & Starting Prices
      </a>
    </div>
  </div>
</section>
