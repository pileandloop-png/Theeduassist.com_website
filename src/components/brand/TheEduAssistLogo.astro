---
// src/components/brand/TheEduAssistLogo.astro
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 400 400"
  class="w-full h-full max-w-full max-h-full"
  aria-label="TheEduAssist logo"
  role="img"
>
  <title>TheEduAssist Logo</title>

  <!-- Definitions -->
  <defs>
    <!-- Light Green Outer Ring: #77BA55 -->
    <path id="topTextPath" d="M 50,200 A 150,150 0 0,1 350,200" fill="transparent" />
    <path id="bottomTextPath" d="M 350,200 A 150,150 0 0,1 50,200" fill="transparent" />
  </defs>

  <!-- 1. Outermost White Border -->
  <circle cx="200" cy="200" r="195" fill="none" stroke="#FFFFFF" stroke-width="2" />

  <!-- 2. Light Green Outer Ring (#77BA55) -->
  <circle cx="200" cy="200" r="190" fill="#77BA55" />

  <!-- 3. Middle White Border -->
  <circle cx="200" cy="200" r="140" fill="none" stroke="#FFFFFF" stroke-width="3" />

  <!-- 4. Dark Slate Blue Inner Circle (#27496D) -->
  <circle cx="200" cy="200" r="137" fill="#27496D" />

  <!-- 5. Text on Outer Ring (White, Sans-serif, Bold, All Caps) -->
  <!-- Top Text: THEEDUASSIST -->
  <text fill="#FFFFFF" font-family="sans-serif" font-weight="bold" font-size="34" letter-spacing="4">
    <textPath href="#topTextPath" startOffset="50%" text-anchor="middle">
      THEEDUASSIST
    </textPath>
  </text>

  <!-- Bottom Text: E-LEARNING DESIGN AGENCY -->
  <text fill="#FFFFFF" font-family="sans-serif" font-weight="bold" font-size="20" letter-spacing="2">
    <textPath href="#bottomTextPath" startOffset="50%" text-anchor="middle">
      E-LEARNING DESIGN AGENCY
    </textPath>
  </text>

  <!-- 6. Separator Stars (White) -->
  <g fill="#FFFFFF">
    <!-- Left Star -->
    <polygon points="50,200 55,215 70,215 58,225 62,240 50,230 38,240 42,225 30,215 45,215" transform="translate(10, -20) scale(0.6) rotate(-15 50 200)" />
    <!-- Right Star -->
    <polygon points="350,200 355,215 370,215 358,225 362,240 350,230 338,240 342,225 330,215 345,215" transform="translate(-10, -20) scale(0.6) rotate(15 350 200)" />
  </g>

  <!-- 7. Inner Graphics (White) -->

  <!-- A. Open Book (Bottom Base) -->
  <!-- Stylized multi-layered pages -->
  <path d="M 120,270 Q 160,285 200,270 Q 240,285 280,270 L 270,300 Q 240,315 200,300 Q 160,315 130,300 Z" fill="#FFFFFF" />
  <path d="M 130,260 Q 165,275 200,260 Q 235,275 270,260 L 280,270 Q 240,285 200,270 Q 160,285 120,270 Z" fill="#FFFFFF" opacity="0.8" />
  <path d="M 140,250 Q 170,265 200,250 Q 230,265 260,250 L 270,260 Q 235,275 200,260 Q 165,275 130,260 Z" fill="#FFFFFF" opacity="0.6" />

  <!-- B. Desktop Monitor (Center Focus) -->
  <!-- Stand -->
  <rect x="192" y="220" width="16" height="30" fill="#FFFFFF" />
  <path d="M 170,250 L 230,250 L 240,260 L 160,260 Z" fill="#FFFFFF" />
  <!-- Screen Frame -->
  <rect x="130" y="140" width="140" height="90" rx="8" ry="8" fill="#FFFFFF" />
  <!-- Screen Inner (matching background) -->
  <rect x="138" y="148" width="124" height="74" rx="4" ry="4" fill="#27496D" />

  <!-- C. Graduation Cap (Inside Monitor) -->
  <path d="M 200,160 L 235,175 L 200,190 L 165,175 Z" fill="#FFFFFF" />
  <rect x="175" y="180" width="50" height="20" fill="#FFFFFF" />
  <!-- Tassel -->
  <line x1="200" y1="175" x2="245" y2="185" stroke="#FFFFFF" stroke-width="2" />
  <line x1="245" y1="185" x2="245" y2="205" stroke="#FFFFFF" stroke-width="3" />

  <!-- D. Top Connections (Technology / Network Nodes) -->

  <!-- Wi-Fi Icon (Directly above monitor) -->
  <path d="M 185,130 A 20,20 0 0,1 215,130" fill="none" stroke="#FFFFFF" stroke-width="3" stroke-linecap="round" />
  <path d="M 175,120 A 35,35 0 0,1 225,120" fill="none" stroke="#FFFFFF" stroke-width="3" stroke-linecap="round" />
  <circle cx="200" cy="138" r="4" fill="#FFFFFF" />

  <!-- Central Vertical Dotted Line -->
  <line x1="200" y1="110" x2="200" y2="85" stroke="#FFFFFF" stroke-width="3" stroke-dasharray="4,4" />

  <!-- Top Center Circular Node -->
  <circle cx="200" cy="80" r="8" fill="#FFFFFF" />

  <!-- Symmetrical Circuit Board Lines & Nodes -->
  <!-- Left Side -->
  <path d="M 200,95 L 160,95 L 140,115 L 120,115" fill="none" stroke="#FFFFFF" stroke-width="2" />
  <circle cx="115" cy="115" r="5" fill="#FFFFFF" />

  <path d="M 180,105 L 150,135 L 110,135" fill="none" stroke="#FFFFFF" stroke-width="2" />
  <circle cx="105" cy="135" r="5" fill="#FFFFFF" />

  <!-- Right Side -->
  <path d="M 200,95 L 240,95 L 260,115 L 280,115" fill="none" stroke="#FFFFFF" stroke-width="2" />
  <circle cx="285" cy="115" r="5" fill="#FFFFFF" />

  <path d="M 220,105 L 250,135 L 290,135" fill="none" stroke="#FFFFFF" stroke-width="2" />
  <circle cx="295" cy="135" r="5" fill="#FFFFFF" />

</svg>
