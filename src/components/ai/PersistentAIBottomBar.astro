---
import { aiAssistants } from '../../data/aiAssistants';
---

<div id="ai-bottom-bar" class="fixed bottom-0 left-0 right-0 z-[40] bg-white border-t border-slate-200 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)] transform transition-transform duration-300 translate-y-full" aria-label="AI Assistant Toolkit">

    {/* Minimized Toggle (Pill) - Only visible when bar is minimized */}
    <button id="ai-bar-restore-btn" class="absolute -top-12 left-1/2 transform -translate-x-1/2 bg-brand-navy text-white px-4 py-2 rounded-t-xl text-sm font-bold shadow-lg flex items-center space-x-2 hidden hover:bg-brand-primary transition-colors focus-ring" aria-label="Open AI Assistant">
        <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        <span>AI Assistant</span>
    </button>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex flex-col md:flex-row items-center justify-between gap-4">

        {/* Left: Input & Chips */}
        <div class="flex-1 w-full relative">
            <div class="flex items-center justify-between md:hidden mb-2">
                <span class="text-xs font-bold text-brand-navy uppercase tracking-wider flex items-center">
                    <svg class="w-3 h-3 text-brand-primary mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    AI Assistant
                </span>
                <button type="button" class="ai-bar-close text-slate-400 hover:text-slate-600 focus-ring rounded p-1">
                    <span class="sr-only">Minimize AI Assistant</span>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>
            </div>

            <div class="relative group">
                <input type="text" id="ai-bar-prompt-input" readonly value="Ask AI about this page, compare packages, or help me choose a service…" class="w-full bg-slate-50 border border-slate-200 text-slate-600 text-sm rounded-full py-2 pl-4 pr-24 focus:outline-none focus:ring-2 focus:ring-brand-primary/50 focus:border-brand-primary cursor-pointer truncate" />

                <div class="absolute right-1.5 top-1.5 flex space-x-1">
                    <button type="button" id="ai-bar-copy-btn" class="bg-white border border-slate-200 text-slate-500 hover:text-brand-primary hover:border-brand-primary/30 p-1.5 rounded-full shadow-sm focus-ring transition-colors tooltip-trigger" data-tooltip="Copy Prompt">
                        <span class="sr-only">Copy Prompt</span>
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                    </button>
                </div>
            </div>

            <div class="flex space-x-2 mt-2 overflow-x-auto pb-1 scrollbar-hide text-xs whitespace-nowrap">
                <button type="button" class="ai-chip bg-slate-100 hover:bg-slate-200 text-slate-600 px-3 py-1 rounded-full transition-colors border border-transparent hover:border-slate-300" data-intent="summarize_page">Summarize</button>
                <button type="button" class="ai-chip bg-slate-100 hover:bg-slate-200 text-slate-600 px-3 py-1 rounded-full transition-colors border border-transparent hover:border-slate-300" data-intent="help_choose">Help me choose</button>
                <button type="button" class="ai-chip bg-slate-100 hover:bg-slate-200 text-slate-600 px-3 py-1 rounded-full transition-colors border border-transparent hover:border-slate-300" data-intent="compare_platforms">Compare platforms</button>
                <button type="button" class="ai-chip bg-slate-100 hover:bg-slate-200 text-slate-600 px-3 py-1 rounded-full transition-colors border border-transparent hover:border-slate-300 hidden sm:inline-block" data-intent="explain_pricing">Explain pricing</button>
            </div>
        </div>

        {/* Right: LLM Buttons */}
        <div class="flex items-center space-x-2 md:space-x-3 md:pl-6 md:border-l border-slate-200 w-full md:w-auto overflow-x-auto pb-1 md:pb-0 scrollbar-hide flex-nowrap">
            {aiAssistants.map((assistant) => (
                <button
                    type="button"
                    class="ai-bar-llm-btn flex items-center justify-center w-8 h-8 md:w-10 md:h-10 rounded-full border border-slate-200 bg-white text-slate-500 hover:text-brand-primary hover:border-brand-primary/30 hover:bg-brand-softBg shadow-sm transition-all focus-ring flex-shrink-0"
                    data-ai-id={assistant.id}
                    data-ai-url={assistant.baseUrl}
                    data-ai-name={assistant.name}
                    aria-label={`Open with ${assistant.name}`}
                    title={`Open with ${assistant.name}`}
                >
                    <span class="sr-only">{assistant.name}</span>
                    <Fragment set:html={assistant.iconSvg} />
                </button>
            ))}

            <button type="button" class="ai-bar-close hidden md:flex items-center justify-center w-8 h-8 rounded-full text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors focus-ring ml-2 flex-shrink-0" aria-label="Minimize AI Assistant">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
        </div>
    </div>

    <div id="ai-bar-toast" class="absolute -top-10 right-4 bg-brand-navy text-white text-xs px-3 py-1.5 rounded shadow-md opacity-0 transition-opacity duration-300 pointer-events-none">
        Prompt copied!
    </div>
</div>

<script>
    import { copyAndOpenAI, generatePrompt } from './AIAssistClient';

    document.addEventListener('DOMContentLoaded', () => {
        const bar = document.getElementById('ai-bottom-bar');
        const restoreBtn = document.getElementById('ai-bar-restore-btn');
        const closeBtns = document.querySelectorAll('.ai-bar-close');
        const promptInput = document.getElementById('ai-bar-prompt-input') as HTMLInputElement;
        const copyBtn = document.getElementById('ai-bar-copy-btn');
        const chips = document.querySelectorAll('.ai-chip');
        const llmBtns = document.querySelectorAll('.ai-bar-llm-btn');
        const toast = document.getElementById('ai-bar-toast');

        let currentIntent = 'summarize_page';

        // Initialization logic
        const isMinimized = localStorage.getItem('theeduassist_ai_bar_minimized') === 'true';

        // Slight delay to allow DOM to settle and prevent flash
        setTimeout(() => {
            if (bar) {
                if (isMinimized) {
                    bar.classList.add('translate-y-full');
                    if(restoreBtn) restoreBtn.classList.remove('hidden');
                } else {
                    bar.classList.remove('translate-y-full');
                    if(restoreBtn) restoreBtn.classList.add('hidden');

                    // Adjust body padding to avoid overlapping Tawk
                    document.body.style.paddingBottom = '140px';
                }
            }
        }, 100);

        // State handlers
        function minimizeBar() {
            if (bar) bar.classList.add('translate-y-full');
            if (restoreBtn) restoreBtn.classList.remove('hidden');
            localStorage.setItem('theeduassist_ai_bar_minimized', 'true');
            document.body.style.paddingBottom = '0px';
        }

        function restoreBar() {
            if (bar) bar.classList.remove('translate-y-full');
            if (restoreBtn) restoreBtn.classList.add('hidden');
            localStorage.setItem('theeduassist_ai_bar_minimized', 'false');
            document.body.style.paddingBottom = '140px';
        }

        function showToast(msg: string) {
            if (!toast) return;
            toast.textContent = msg;
            toast.classList.remove('opacity-0');
            setTimeout(() => {
                toast.classList.add('opacity-0');
            }, 3000);
        }

        // Listeners
        closeBtns.forEach(btn => btn.addEventListener('click', minimizeBar));
        if (restoreBtn) restoreBtn.addEventListener('click', restoreBar);

        // Update intent based on chips
        chips.forEach(chip => {
            chip.addEventListener('click', (e) => {
                const target = e.currentTarget as HTMLButtonElement;
                const intent = target.dataset.intent || 'summarize_page';
                currentIntent = intent;

                // Update active styling
                chips.forEach(c => {
                    c.classList.remove('bg-brand-primary', 'text-white', 'border-brand-primary');
                    c.classList.add('bg-slate-100', 'text-slate-600', 'border-transparent');
                });
                target.classList.remove('bg-slate-100', 'text-slate-600', 'border-transparent');
                target.classList.add('bg-brand-primary', 'text-white', 'border-brand-primary');

                // Update input display text to show intent
                if(promptInput) {
                    promptInput.value = `Intent: ${target.textContent} — ready to copy to AI...`;
                }
            });
        });

        // Copy button manual copy
        if (copyBtn && promptInput) {
            copyBtn.addEventListener('click', async () => {
                try {
                    const fullPrompt = generatePrompt(currentIntent);
                    await navigator.clipboard.writeText(fullPrompt);
                    showToast('Prompt copied! Paste in your AI.');
                } catch(e) {
                    console.error('Copy failed', e);
                }
            });
        }

        // Input click copies too
        if(promptInput) {
             promptInput.addEventListener('click', async () => {
                 try {
                    const fullPrompt = generatePrompt(currentIntent);
                    await navigator.clipboard.writeText(fullPrompt);
                    showToast('Prompt copied!');
                } catch(e) {}
             });
        }

        // LLM dispatch
        llmBtns.forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const target = e.currentTarget as HTMLButtonElement;
                const url = target.dataset.aiUrl || '';
                const name = target.dataset.aiName || '';

                showToast(`Opening ${name}...`);
                await copyAndOpenAI(currentIntent, url, name);
            });
        });
    });
</script>

<style>
    /* Hide scrollbar for clean horizontal scroll */
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
