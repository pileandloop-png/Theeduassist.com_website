---
import { aiAssistants } from '../../data/aiAssistants';
---
<div id="ai-bottom-bar" class="fixed bottom-0 left-0 right-0 z-[40] bg-white/95 backdrop-blur-md border-t border-slate-200 shadow-[0_-4px_20px_rgba(0,0,0,0.05)] transform transition-transform duration-300 translate-y-0" aria-label="AI Assistant Toolbar">

    <!-- Collapse Toggle Button -->
    <button type="button" id="ai-bar-toggle" class="absolute -top-10 left-4 bg-white border border-slate-200 border-b-0 px-4 py-2 rounded-t-lg shadow-[0_-4px_10px_rgba(0,0,0,0.03)] text-xs font-bold text-slate-500 hover:text-brand-primary flex items-center gap-2 focus-ring transition-colors" aria-expanded="true">
        <svg id="ai-bar-toggle-icon" class="w-4 h-4 transition-transform duration-300 transform rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        AI Assistant
    </button>

    <div class="max-w-7xl mx-auto px-4 py-3 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-4">

        <!-- Left Side: Context Input Simulation -->
        <div class="flex-1 w-full relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-brand-primary">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <div class="block w-full pl-10 pr-4 py-2.5 border border-slate-200 rounded-full bg-slate-50 text-sm text-slate-500 truncate cursor-not-allowed select-none">
                Ask AI about this page, compare packages, or help me choose a service…
            </div>
        </div>

        <!-- Right Side: Action Buttons -->
        <div class="flex items-center gap-2 overflow-x-auto w-full md:w-auto pb-1 md:pb-0 scrollbar-hide">

            <button type="button" id="ai-copy-prompt-btn" class="flex-shrink-0 bg-slate-100 hover:bg-slate-200 text-slate-700 px-4 py-2 rounded-full text-sm font-bold transition-colors focus-ring border border-slate-200 shadow-sm flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                Copy Prompt
            </button>

            <div class="w-px h-6 bg-slate-200 mx-1 flex-shrink-0"></div>

            {aiAssistants.map(ai => (
                <button type="button" class="ai-bottom-btn flex-shrink-0 p-2 rounded-full hover:bg-brand-softBg text-slate-500 hover:text-brand-primary transition-colors focus-ring" title={`Open ${ai.name}`} data-ai-name={ai.name} data-ai-url={ai.baseUrl}>
                    <span class="sr-only">Open {ai.name}</span>
                    <img src={ai.iconPath} alt={ai.name} class="w-6 h-6 object-contain" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                    <svg class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"></path></svg>
                </button>
            ))}

        </div>
    </div>
</div>

<script>
    import { copyAndOpenAI, generateFullPrompt } from './AIAssistClient';

    document.addEventListener('DOMContentLoaded', () => {
        const bar = document.getElementById('ai-bottom-bar');
        const toggle = document.getElementById('ai-bar-toggle');
        const toggleIcon = document.getElementById('ai-bar-toggle-icon');
        const copyBtn = document.getElementById('ai-copy-prompt-btn');

        // Restore state
        const isMinimized = localStorage.getItem('aiBarMinimized') === 'true';
        if (isMinimized && bar && toggleIcon) {
            bar.classList.add('translate-y-full');
            toggleIcon.classList.remove('rotate-180');
            toggle?.setAttribute('aria-expanded', 'false');
        }

        // Toggle logic
        toggle?.addEventListener('click', () => {
            if (!bar || !toggleIcon) return;
            const isCurrentlyMinimized = bar.classList.contains('translate-y-full');

            if (isCurrentlyMinimized) {
                bar.classList.remove('translate-y-full');
                toggleIcon.classList.add('rotate-180');
                toggle.setAttribute('aria-expanded', 'true');
                localStorage.setItem('aiBarMinimized', 'false');
            } else {
                bar.classList.add('translate-y-full');
                toggleIcon.classList.remove('rotate-180');
                toggle.setAttribute('aria-expanded', 'false');
                localStorage.setItem('aiBarMinimized', 'true');
            }
        });

        // Copy plain text prompt
        copyBtn?.addEventListener('click', async () => {
            const prompt = generateFullPrompt('help_me_choose');
            try {
                await navigator.clipboard.writeText(prompt);

                // Show global toast
                const toastEvent = new CustomEvent('show-ai-toast', {
                    detail: { title: "Prompt Copied", message: "Paste it into any AI tool to get help choosing a package." }
                });
                window.dispatchEvent(toastEvent);

                // Change button state temporarily
                const originalText = copyBtn.innerHTML;
                copyBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Copied!';
                copyBtn.classList.add('text-brand-accent', 'border-brand-accent');

                setTimeout(() => {
                    copyBtn.innerHTML = originalText;
                    copyBtn.classList.remove('text-brand-accent', 'border-brand-accent');
                }, 2000);

            } catch (err) {
                console.error("Failed to copy", err);
            }
        });

        // LLM buttons
        const aiBtns = document.querySelectorAll('.ai-bottom-btn');
        aiBtns.forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const target = e.currentTarget as HTMLButtonElement;
                const url = target.dataset.aiUrl || '';
                const name = target.dataset.aiName || '';

                await copyAndOpenAI('help_me_choose', url, name);
            });
        });
    });
</script>

<style>
    /* Hide scrollbar for the button row */
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
