---
import FormField from './FormField.astro';
import TextAreaField from './TextAreaField.astro';
import SelectField from './SelectField.astro';
import HiddenTrackingFields from './HiddenTrackingFields.astro';

const helpOptions = [
  { value: 'Course Creation', label: 'Course Creation' },
  { value: 'Kajabi Setup', label: 'Kajabi Setup' },
  { value: 'LMS Migration', label: 'LMS Migration' },
  { value: 'AI-Powered E-Learning Support', label: 'AI-Powered E-Learning Support' },
  { value: 'Content Conversion', label: 'Content Conversion' },
  { value: 'Funnels & Automation', label: 'Funnels & Automation' },
  { value: 'Ongoing Support', label: 'Ongoing Support' },
  { value: 'Not Sure Yet', label: 'Not Sure Yet' }
];

const platformOptions = [
  { value: 'Kajabi', label: 'Kajabi' },
  { value: 'WordPress', label: 'WordPress' },
  { value: 'Google Drive / files only', label: 'Google Drive / files only' },
  { value: 'Old LMS', label: 'Old LMS' },
  { value: 'Thinkific / Teachable-style platform', label: 'Thinkific / Teachable-style platform' },
  { value: 'Moodle-style LMS', label: 'Moodle-style LMS' },
  { value: 'Custom course website', label: 'Custom course website' },
  { value: 'Not using a platform yet', label: 'Not using a platform yet' },
  { value: 'Other', label: 'Other' }
];

const timelineOptions = [
  { value: 'ASAP', label: 'ASAP' },
  { value: '2 to 4 weeks', label: '2 to 4 weeks' },
  { value: '1 to 2 months', label: '1 to 2 months' },
  { value: '3+ months', label: '3+ months' },
  { value: 'Not sure yet', label: 'Not sure yet' }
];

const budgetOptions = [
  { value: 'Under $500', label: 'Under $500' },
  { value: '$500 to $1,500', label: '$500 to $1,500' },
  { value: '$1,500 to $3,500', label: '$1,500 to $3,500' },
  { value: '$3,500 to $8,000', label: '$3,500 to $8,000' },
  { value: '$8,000+', label: '$8,000+' },
  { value: 'Not sure yet', label: 'Not sure yet' }
];

---

<!-- TODO: Implement backend integration. Using mailto: fallback for now. -->
<form class="space-y-8" id="audit-form">
  <HiddenTrackingFields formType="audit" />

  <div class="bg-slate-50 p-6 rounded-lg border border-slate-200">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
      <FormField name="fullName" label="Name" required={true} placeholder="Your Name" />
      <FormField name="email" label="Email" type="email" required={true} placeholder="Your Email" />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
      <FormField name="company" label="Company / Brand" required={true} placeholder="Company Name" />
      <SelectField name="servicesNeeded" label="What do you need help with?" options={helpOptions} required={true} />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
      <SelectField name="platform" label="Current platform" options={platformOptions} required={true} />
      <SelectField name="budgetRange" label="Budget range" options={budgetOptions} required={true} />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
      <SelectField name="timeline" label="Timeline" options={timelineOptions} required={true} />
    </div>
    <div class="mt-5">
      <TextAreaField name="projectDescription" label="Short project description" required={true} placeholder="Tell us a little bit about what you're building..." rows={4} />
    </div>
  </div>

  <div class="flex items-start bg-blue-50 p-4 rounded-md border border-blue-100">
    <div class="flex h-5 items-center">
      <input
        id="consent"
        name="consent"
        type="checkbox"
        required
        class="h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500"
      />
    </div>
    <div class="ml-3 text-sm">
      <label for="consent" class="font-medium text-blue-900">
        I understand this request helps TheEduAssist review my project and recommend the right next step.
      </label>
    </div>
  </div>

  <p class="text-xs text-slate-500">
    We use your details only to review your request and respond with the right next step. Do not upload confidential files through this form.
  </p>

  <div id="form-success-message" class="hidden bg-green-50 text-green-800 p-4 rounded-md border border-green-200 mb-6">
      Thanks. TheEduAssist will review your request and reply within 24–48 hours with the best service path, estimated scope, and next step.
  </div>

  <button type="submit" class="bg-[#77BA55] hover:bg-green-600 text-white px-8 py-4 rounded-md font-bold text-lg transition-colors w-full md:w-auto focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600" id="submit-audit-btn">
    Send Request via Email
  </button>
</form>

<script>
  document.getElementById('audit-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);

    const name = formData.get('fullName') || '';
    const email = formData.get('email') || '';
    const company = formData.get('company') || '';

    const services = formData.get('servicesNeeded') || 'None';

    const platform = formData.get('platform') || '';
    const desc = formData.get('projectDescription') || '';
    const timeline = formData.get('timeline') || '';
    const budget = formData.get('budgetRange') || '';

    const body = `Name: ${name}\nEmail: ${email}\nCompany: ${company}\n\n--- PROJECT ---\nHelp With: ${services}\nPlatform: ${platform}\nBudget: ${budget}\nTimeline: ${timeline}\n\nDescription:\n${desc}`;

    window.location.href = `mailto:Info@theeduassist.com?subject=24-48 Hour Review Request - ${encodeURIComponent(company.toString())}&body=${encodeURIComponent(body)}`;

    const btn = document.getElementById('submit-audit-btn') as HTMLButtonElement;
    const successMsg = document.getElementById('form-success-message');

    if(successMsg) {
       successMsg.classList.remove('hidden');
    }

    if(btn) {
      btn.innerText = 'Opening Email App...';
      setTimeout(() => {
        window.location.href = '/thank-you/';
      }, 2000);
    }
  });
</script>
