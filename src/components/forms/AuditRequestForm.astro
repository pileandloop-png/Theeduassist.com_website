---
import FormField from './FormField.astro';
import TextAreaField from './TextAreaField.astro';
import SelectField from './SelectField.astro';
import HiddenTrackingFields from './HiddenTrackingFields.astro';
import TurnstileWidget from './TurnstileWidget.astro';

const reviewOptions = [
  { value: 'kajabi_setup', label: 'Kajabi setup' },
  { value: 'lms_setup', label: 'LMS setup' },
  { value: 'course_structure', label: 'Course structure' },
  { value: 'course_upload', label: 'Course upload/content organization' },
  { value: 'funnel_automation', label: 'Funnel and email automation' },
  { value: 'learner_experience', label: 'Learner experience' },
  { value: 'migration_readiness', label: 'Migration readiness' },
  { value: 'launch_plan', label: 'Overall launch plan' },
];

const nextStepOptions = [
  { value: 'book_session', label: 'Book a 30-minute session' },
  { value: 'written_rec', label: 'Get a written recommendation' },
  { value: 'proposal', label: 'Discuss a build proposal' },
  { value: 'notsure', label: 'Not sure yet' },
];
---

<form action="/api/submit-lead" method="POST" class="space-y-5" id="audit-form">
  <HiddenTrackingFields formType="audit" />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <FormField name="fullName" label="Full Name" required={true} placeholder="Your Name" />
    <FormField name="email" label="Email Address" type="email" required={true} placeholder="Your Email" />
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <FormField name="websiteOrCourseLink" label="Website or Course Link" type="url" required={true} placeholder="https://..." />
    <FormField name="platform" label="Platform" placeholder="e.g. Kajabi, LearnWorlds, Teachable" />
  </div>

  <SelectField name="whatToReview" label="What do you want reviewed?" options={reviewOptions} required={true} />

  <TextAreaField name="mainChallenge" label="Main Challenge" required={true} placeholder="What is your biggest roadblock right now?" rows={4} />

  <SelectField name="preferredNextStep" label="Preferred Next Step" options={nextStepOptions} required={true} />

  <TurnstileWidget />

  <p class="text-xs text-slate-500">By submitting this form, you agree to our Privacy Policy.</p>

  <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-md font-medium transition-colors w-full md:w-auto" id="submit-audit-btn">
    Request Audit
  </button>
</form>

<script>
  document.getElementById('audit-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-audit-btn') as HTMLButtonElement;
    if(btn) {
      btn.disabled = true;
      btn.innerText = 'Submitting...';
    }

    setTimeout(() => {
      window.location.href = '/thank-you/?type=audit';
    }, 1000);
  });
</script>
