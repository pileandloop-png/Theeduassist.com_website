---
import Layout from "../../layouts/Layout.astro";
import ServicesHero from "../../components/services/ServicesHero.astro";

// Fallback or placeholder for the pricing page
---
<Layout title="Pricing | TheEduAssist" description="Pricing for E-learning design and course creation packages.">
  <ServicesHero />
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-brand-navy mb-8">Our Pricing Packages</h2>
      <p class="text-lg text-slate-600 mb-12">
        We offer standard packages starting from $500, as well as customized enterprise solutions.
        Please note that 'starting from' prices are a guide and not fixed final quotes.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-slate-50 rounded-xl p-8 border border-slate-200">
           <h3 class="text-xl font-bold text-brand-navy mb-2">Review & Strategy</h3>
           <p class="text-2xl font-bold text-brand-primary mb-4">From $500</p>
           <p class="text-slate-600 mb-6">Audits, curriculum planning, and LMS strategy sessions.</p>
           <button type="button" class="w-full tawk-package-btn bg-white border border-slate-300 text-slate-700 py-3 rounded-md hover:border-brand-primary font-bold" data-package="review_strategy">Talk to Sales</button>
        </div>
        <div class="bg-brand-navy rounded-xl p-8 border border-brand-navy shadow-lg relative transform md:-translate-y-4">
           <div class="absolute top-0 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-brand-accent text-white px-4 py-1 rounded-full text-xs font-bold tracking-wide uppercase">Most Popular</div>
           <h3 class="text-xl font-bold text-white mb-2">Course Build</h3>
           <p class="text-2xl font-bold text-brand-accent mb-4">From $2,500</p>
           <p class="text-slate-300 mb-6">Complete course creation on Kajabi, Thinkific, or Moodle.</p>
           <button type="button" class="w-full tawk-package-btn bg-brand-accent text-white py-3 rounded-md hover:bg-white hover:text-brand-navy font-bold transition-colors" data-package="course_build">Start This Package</button>
        </div>
        <div class="bg-slate-50 rounded-xl p-8 border border-slate-200">
           <h3 class="text-xl font-bold text-brand-navy mb-2">Enterprise Solutions</h3>
           <p class="text-xl font-bold text-brand-primary mb-4">Custom Quote</p>
           <p class="text-slate-600 mb-6">Large-scale LMS implementations and custom SCORM design.</p>
           <button type="button" class="w-full tawk-package-btn bg-white border border-slate-300 text-slate-700 py-3 rounded-md hover:border-brand-primary font-bold" data-package="enterprise">Talk to Sales</button>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { openPlatformSalesChat } from "../../utils/tawkSales";

    document.addEventListener("DOMContentLoaded", () => {
      const btns = document.querySelectorAll(".tawk-package-btn");
      btns.forEach(btn => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const target = e.currentTarget as HTMLButtonElement;

          openPlatformSalesChat({
            selected_platform: "pricing_page",
            recommended_package: target.dataset.package || "",
            sourceCta: "pricing-page-package",
            lead_intent: "package_inquiry"
          });
        });
      });
    });
  </script>
</Layout>
