---
import Layout from "../../layouts/Layout.astro";
import AuditHero from "../../components/audit/AuditHero.astro";
import AuditReviewScope from "../../components/audit/AuditReviewScope.astro";
import CalendlyCTA from "../../components/audit/CalendlyCTA.astro";
import AuditNextSteps from "../../components/audit/AuditNextSteps.astro";
import AuditFAQ from "../../components/audit/AuditFAQ.astro";
import { webPageSchema, faqPageSchema, breadcrumbSchema } from '../../lib/schema';

// Required FAQ array for the Schema
const auditFaqs = [
  {
    question: "Is the audit really free?",
    answer: "Yes. The audit request helps us understand your project and recommend the right next step. Full implementation work is quoted separately."
  },
  {
    question: "Do I need to have course content ready?",
    answer: "No. You can submit an idea, rough notes, existing content, Kajabi setup, LMS, or scattered files."
  },
  {
    question: "Can you review my Kajabi setup?",
    answer: "Yes. Kajabi is one of our strongest specialties."
  },
  {
    question: "Can you review LMS or WordPress content?",
    answer: "Yes. We can review LMS content, WordPress course pages, Google Drive folders, PDFs, videos, and other training materials."
  },
  {
    question: "Will you give pricing?",
    answer: "We can recommend a package or custom quote after reviewing your audit details. Pricing depends on scope, content volume, platform, timeline, and launch needs."
  },
  {
    question: "Do you guarantee sales?",
    answer: "No. We help improve structure, learning experience, platform setup, funnels, and launch readiness, but sales depend on offer, audience, traffic, pricing, trust, and other factors."
  }
];

const jsonLd = [
  webPageSchema(
    "Get a 24–48 Hour Course/LMS Review | TheEduAssist",
    "Submit your course, Kajabi, LMS, content conversion, AI e-learning, funnel, or support request and TheEduAssist will reply within 24–48 hours with the best service path, estimated scope, and next step.",
    "/book-free-audit/"
  ),
  faqPageSchema(auditFaqs),
  breadcrumbSchema([
    { name: "Home", urlPath: "/" },
    { name: "Get 24–48 Hour Review", urlPath: "/book-free-audit/" }
  ])
];

const trustChips = [
  "Free Audit",
  "Course Review",
  "Kajabi Review",
  "LMS Review",
  "Content Review",
  "Funnel Review",
  "Launch Review"
];
---
<Layout
  title="Get a 24–48 Hour Course/LMS Review | TheEduAssist"
  description="Submit your course, Kajabi, LMS, content conversion, AI e-learning, funnel, or support request and TheEduAssist will reply within 24–48 hours with the best service path, estimated scope, and next step."
  canonicalPath="/book-free-audit/"
  jsonLd={jsonLd}
>

  <AuditHero
    title="Get a 24–48 Hour Course/LMS Review"
    subtitle="Tell us what you are building, fixing, migrating, converting, or launching. TheEduAssist will review your request and recommend the right service path, estimated scope, and next step within 24–48 hours."
    primaryCtaLabel="Start Request Form"
    primaryCtaLink="#audit-form-section"
    secondaryCtaLabel="Email Instead"
    secondaryCtaLink="mailto:Info@theeduassist.com"
    trustChips={trustChips}
  />

  <AuditReviewScope />

  <section id="audit-form-section" class="py-24 bg-slate-50 border-t border-slate-200">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-white p-4 md:p-10 rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <h2 class="text-3xl font-bold mb-8 text-center text-slate-900">Tell Us About Your Project</h2>

        <!-- Google Form Setup Note:
             - Create the form under Info@theeduassist.com
             - Link responses to Google Sheet
             - Turn on new response email notifications
             - Use prefilled links later for service-specific CTAs
             - Avoid file upload for now
             - Ask users to share links instead of confidential files
        -->
        <div class="w-full relative min-h-[800px] rounded-lg overflow-hidden border border-slate-100">
          <iframe
            src="GOOGLE_FORM_EMBED_URL"
            width="100%"
            height="100%"
            class="absolute top-0 left-0 w-full h-full border-0"
            title="24-48 Hour Review Request Form"
          >Loading…</iframe>
        </div>

        <div class="mt-8 text-center border-t border-slate-100 pt-6">
          <p class="text-slate-600 mb-4">Having trouble viewing the form?</p>
          <a
            href="GOOGLE_FORM_PUBLIC_URL"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center bg-white text-blue-600 border border-blue-200 hover:bg-blue-50 px-6 py-3 rounded-md font-semibold transition-colors"
          >
            Open the review form in a new tab
          </a>
        </div>
      </div>
    </div>
  </section>

  <CalendlyCTA />

  <AuditNextSteps />

  <AuditFAQ />

</Layout>
