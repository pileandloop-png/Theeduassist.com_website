---
import Layout from "../../layouts/Layout.astro";
import HomeHero from "../../components/sections/HomeHero.astro";
import CaseStudyPreviewGrid from "../../components/sections/CaseStudyPreviewGrid.astro";
import FinalCTA from "../../components/sections/FinalCTA.astro";
---
<Layout title="Case Studies" description="Explore how TheEduAssist has helped clients structure, migrate, and build professional learning solutions.">

  <HomeHero
    title="Client Case Studies"
    subtitle="Real projects. Real outcomes. We focus on practical delivery and clear results without relying on fake metrics or exaggerated claims."
    primaryCtaLabel="Book Free Audit"
    primaryCtaLink="/book-free-audit/"
  />

  <section class="py-12 bg-amber-50 border-y border-amber-200">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-amber-800 font-medium flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
        </svg>
        Detailed case study content, including specific implementations and methodologies, will be refined during our upcoming platform migration.
      </p>
    </div>
  </section>

  <div class="pt-12">
    <CaseStudyPreviewGrid />
  </div>

  <FinalCTA
    title="Want to discuss a similar project?"
    subtitle="Let's look at your requirements and see how we can help."
  />

</Layout>
