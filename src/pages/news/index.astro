---
import Layout from "../../layouts/Layout.astro";

---
<Layout title="News | TheEduAssist" description="Follow TheEduAssist news, platform updates, course-building insights, and company announcements.">

  <section class="bg-brand-navy pt-24 pb-16 text-white text-center">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">News</h1>
      <p class="text-xl text-slate-300">Company updates, insights, and platform news.</p>
    </div>
  </section>

  <section class="py-20 bg-white min-h-[50vh] flex flex-col justify-center">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

      <div class="bg-slate-50 p-12 rounded-xl border border-slate-200 shadow-sm mb-12">
          <p class="text-lg text-slate-600">
            Company news and updates will be added here as TheEduAssist expands its services, platform support, and learning design resources.
          </p>
      </div>

      <div class="mt-8 flex justify-center space-x-6">
          <a href="/blog/" class="inline-block bg-white border-2 border-brand-primary text-brand-primary hover:bg-brand-primary hover:text-white font-bold py-3 px-6 rounded transition-colors duration-300">
              Read Our Blog
          </a>
          <a href="/press-releases/" class="inline-block bg-white border-2 border-brand-navy text-brand-navy hover:bg-brand-navy hover:text-white font-bold py-3 px-6 rounded transition-colors duration-300">
              Press Releases
          </a>
      </div>

    </div>
  </section>
</Layout>
