---
import Layout from "../../layouts/Layout.astro";

// Use a simple layout since we don't have a specific Hero component for this yet.
// Alternatively, we could create a new Hero component or use a generic one.
---
<Layout title="Press Releases | TheEduAssist" description="Read official announcements, company updates, and media releases from TheEduAssist.">

  <section class="bg-brand-navy pt-24 pb-16 text-white text-center">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Press Releases</h1>
      <p class="text-xl text-slate-300">Official announcements and media updates from TheEduAssist.</p>
    </div>
  </section>

  <section class="py-20 bg-white min-h-[50vh] flex flex-col justify-center">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

      <div class="bg-slate-50 p-12 rounded-xl border border-slate-200 shadow-sm mb-12">
          <p class="text-lg text-slate-600">
            Official press releases will be published here as TheEduAssist shares company updates, partnerships, launches, and media announcements.
          </p>
      </div>

      <div class="bg-brand-navy text-white p-8 rounded-xl shadow-lg max-w-2xl mx-auto">
          <h3 class="text-xl font-bold mb-4">Media Inquiries</h3>
          <p class="mb-6">For media or partnership inquiries, contact:</p>
          <a href="mailto:Info@theeduassist.com" class="inline-block bg-brand-accent hover:bg-white hover:text-brand-navy text-white font-bold py-3 px-6 rounded transition-colors duration-300">
              Info@theeduassist.com
          </a>
      </div>

      <div class="mt-8 flex justify-center space-x-4">
          <a href="/brand-assets/" class="text-brand-primary hover:text-brand-navy font-medium underline">Brand Assets</a>
          <span class="text-slate-300">|</span>
          <a href="/contact/" class="text-brand-primary hover:text-brand-navy font-medium underline">Contact</a>
      </div>

    </div>
  </section>
</Layout>
