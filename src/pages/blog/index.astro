---
import Layout from "../../layouts/Layout.astro";
import HomeHero from "../../components/sections/HomeHero.astro";
---
<Layout title="Blog" description="TheEduAssist Blog - Insights on eLearning, Kajabi, and LMS solutions.">

  <HomeHero
    title="TheEduAssist Blog"
    subtitle="Insights and practical advice on course design, platform setup, and eLearning strategy."
    primaryCtaLabel="Book Free Audit"
    primaryCtaLink="/book-free-audit/"
  />

  <section class="py-24 bg-white text-center px-4">
    <div class="max-w-3xl mx-auto bg-slate-50 p-10 rounded-lg border border-slate-200">
      <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
      </div>
      <h2 class="text-2xl font-bold mb-4 text-slate-900">Content Migration in Progress</h2>
      <p class="text-lg text-slate-600 leading-relaxed mb-6">
        Blog migration is scheduled after the main website launch. Priority articles on Kajabi, LMS, AI-powered learning, and custom eLearning will be migrated in the next phase.
      </p>
      <a href="/services/" class="text-blue-600 font-medium hover:underline">Explore our services in the meantime &rarr;</a>
    </div>
  </section>

</Layout>
